// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
	"name": "Music",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/base:noble",
	"features": {
		"ghcr.io/devcontainers/features/go:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/nils-geistmann/devcontainers-features/zsh:0": {},
		//"sshd": "latest"
		"ghcr.io/siri404/devcontainer-ai-features/gemini-cli:1": {}
	},
	"mounts": [
		// Format: source=LOCAL_PATH,target=CONTAINER_PATH,type=bind
		"source=/home/simon/.gramophile,target=/home/vscode/.gramophile,type=bind",
	    "source=/home/simon/.ssh,target=/home/vscode/.ssh,type=bind",
	    		"source=/var/run/dbus,target=/var/run/dbus,type=bind",
	    "source=/run/user,target=/run/user,type=bind",
	    	    "source=${localEnv:HOME}/.gemini,target=/home/vscode/.gemini,type=bind"
	],
"initializeCommand": "cat ~/.seraphine-automation > .devcontainer/.env.auth",
	"runArgs": [
		"--security-opt",
		"label=disable",
		"--env-file",
		"${localWorkspaceFolder}/.devcontainer/.env.auth"
	],
	"remoteOTEL.enabled": true,
	"forwardPorts": [],
	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],
	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "uname -a",
	// This runs tmux on startup
	"postCreateCommand": "./postCreate.sh",
	// Configure tool-specific properties.
	// "customizations": {},
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
	"containerEnv": {
	    "GH_GIT_PROTOCOL": "ssh",
	    	"DBUS_SESSION_BUS_ADDRESS": "unix:path=/run/user/1000/bus",
		"LANG": "en_US.UTF-8",
		"LC_ALL": "en_US.UTF-8",
		"TZ": "America/Los_Angeles"
	},
	"workspaceFolder": "/workspaces/music"
}
